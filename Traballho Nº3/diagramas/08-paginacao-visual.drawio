          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="map4" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="vpage4" target="pte_r4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="map5" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#82b366;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="vpage5" target="pte_r5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys0" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r0" target="phys_f17">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys1" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r1_f" target="phys_f3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys2" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r2_f" target="phys_f42">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys3" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r3_f" target="phys_f20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys4_disk" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#666666;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r4_f" target="swap_disk">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="phys5" style="endArrow=classic;html=1;strokeWidth=1.5;strokeColor=#6c8ebf;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pte_r5_f" target="phys_f99">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cr3_arrow" value="&lt;b&gt;CR3 (registrador da CPU)&lt;/b&gt;&lt;br&gt;aponta para a raiz da tabela&lt;br&gt;(trocado em cada context switch)" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="500" y="450" width="540" height="50" as="geometry" />
        </mxCell>
        <mxCell id="fault_panel" value="&lt;b&gt;Acesso à Página 4 → PAGE FAULT&lt;/b&gt;&lt;br&gt;&lt;br&gt;MMU verifica PTE: P=0 → exceção. Kernel detecta tipo:&lt;br&gt;• major fault: traz a página da área de swap para um frame livre&lt;br&gt;• atualiza PTE (P=1, frame correto)&lt;br&gt;• invalida TLB&lt;br&gt;• retoma instrução (que agora terá sucesso)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="620" width="700" height="160" as="geometry" />
        </mxCell>
        <mxCell id="hierarchy_panel" value="&lt;b&gt;TABELA HIERÁRQUICA (x86-64, 4 níveis)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Endereço virtual de 48 bits dividido em 4 índices de 9 bits + offset de 12 bits.&lt;br&gt;&lt;br&gt;CR3 → &lt;b&gt;PGD&lt;/b&gt; → &lt;b&gt;PUD&lt;/b&gt; → &lt;b&gt;PMD&lt;/b&gt; → &lt;b&gt;PTE&lt;/b&gt; → Frame + Offset&lt;br&gt;&lt;br&gt;Cada nível: 512 entradas (8 bytes × 512 = 4 KiB = uma página).&lt;br&gt;Tabelas vazias NÃO são criadas — economiza muito espaço.&lt;br&gt;CPUs novas têm 5 níveis (PML5) cobrindo 128 PiB." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="620" width="700" height="160" as="geometry" />
        </mxCell>
        <mxCell id="replacement_title" value="SUBSTITUIÇÃO DE PÁGINA (quando RAM enche)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="77" y="800" width="1500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="alg_fifo" value="&lt;b&gt;FIFO&lt;/b&gt;&lt;br&gt;mais antiga sai&lt;br&gt;&lt;span style='color:#b85450'&gt;ruim&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg_lru" value="&lt;b&gt;LRU&lt;/b&gt;&lt;br&gt;menos recentemente usada&lt;br&gt;&lt;span style='color:#82b366'&gt;ótimo&lt;/span&gt; • impl. cara" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="340" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg_clock" value="&lt;b&gt;Clock / LRU aprox&lt;/b&gt;&lt;br&gt;bit A + ponteiro circular&lt;br&gt;&lt;span style='color:#82b366'&gt;usado na prática&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="580" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg_lru_linux" value="&lt;b&gt;Linux: 2 listas LRU&lt;/b&gt;&lt;br&gt;active + inactive&lt;br&gt;&lt;span style='color:#82b366'&gt;kswapd faz reclaim&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg_ws" value="&lt;b&gt;Working Set&lt;/b&gt;&lt;br&gt;páginas usadas no intervalo&lt;br&gt;&lt;span style='color:#999'&gt;teórico&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1060" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg_lfu" value="&lt;b&gt;LFU&lt;/b&gt;&lt;br&gt;menos frequente&lt;br&gt;&lt;span style='color:#b85450'&gt;sofre mudança de fase&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1300" y="840" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="thrashing_panel" value="&lt;b style='color:#b85450'&gt;THRASHING — o ponto de colapso&lt;/b&gt;&lt;br&gt;Quando o working set total dos processos excede a RAM, o kernel:&lt;br&gt;1) manda página A para swap | 2) processo precisa de A → traz de volta | 3) para trazer, manda B para swap | 4) processo precisa de B → traz...&lt;br&gt;&lt;b&gt;Resultado:&lt;/b&gt; sistema passa mais tempo paginando do que executando. CPU baixa, disco 100%, processos congelados. &lt;b&gt;Solução:&lt;/b&gt; matar processos (OOM killer) ou adicionar RAM." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="930" width="1420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Trabalho Nº3 — System Design da Memória — Seção 8: Paginação e Memória Virtual" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="77" y="1080" width="1500" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
