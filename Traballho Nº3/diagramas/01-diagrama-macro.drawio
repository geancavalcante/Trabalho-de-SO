        </mxCell>
        <mxCell id="leg_questions" value="&lt;b&gt;Perguntas-chave respondidas neste diagrama:&lt;/b&gt;&lt;br&gt;• Quem acessa memória? &lt;b&gt;CPU e processos&lt;/b&gt;&lt;br&gt;• Quem traduz endereço? &lt;b&gt;MMU (com TLB)&lt;/b&gt;&lt;br&gt;• Quem protege? &lt;b&gt;MMU + Kernel&lt;/b&gt;&lt;br&gt;• Quem aloca? &lt;b&gt;Kernel / Gerência VM&lt;/b&gt;&lt;br&gt;• Quem monitora? &lt;b&gt;Ferramentas Linux&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="820" width="640" height="120" as="geometry" />
        </mxCell>
