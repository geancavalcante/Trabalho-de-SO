        </mxCell>
        <mxCell id="leg_orange_t" value="Laranja — Kernel / subsistema de memória" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="890" width="280" height="20" as="geometry" />
