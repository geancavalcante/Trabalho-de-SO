          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5_sim" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#82b366;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5_nao" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s5" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d79b00;" edge="1" parent="1" source="s7" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8_minor" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#d79b00;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s8" target="fault_minor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8_major" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#d79b00;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s8" target="fault_major">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8_invalid" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#b85450;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="fault_minor" target="fault_invalid">
          <mxGeometry relative="1" as="geometry" />
          <Array as="points"><mxPoint x="960" y="930" /></Array>
        </mxCell>
        <mxCell id="a_minor_resolve" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#d79b00;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="fault_minor" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_major_resolve" style="endArrow=classic;html=1;strokeWidth=1;strokeColor=#d79b00;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="fault_major" target="s9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a9_retry" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d79b00;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s9" target="s6">
          <mxGeometry relative="1" as="geometry" />
          <Array as="points"><mxPoint x="240" y="1040" /></Array>
        </mxCell>
        <mxCell id="a9_label" value="repete instrução" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="500" y="1020" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="a6" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#82b366;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s6" target="s10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a10" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="s10" target="s11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cost_table" value="&lt;b&gt;CUSTO RELATIVO&lt;/b&gt;&lt;br&gt;TLB hit: ~1 ciclo&lt;br&gt;TLB miss + walk: dezenas–centenas de ciclos&lt;br&gt;Minor fault: ~μs&lt;br&gt;Major fault (SSD): ~100 μs – 1 ms&lt;br&gt;Major fault (HD): ~10 ms&lt;br&gt;&lt;br&gt;1 major fault custa o equivalente a executar &lt;b&gt;milhões&lt;/b&gt; de instruções." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="690" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="pte_bits" value="&lt;b&gt;BITS DA PTE QUE A MMU CHECA&lt;/b&gt;&lt;br&gt;P — Present (página em RAM?)&lt;br&gt;R/W — escrita permitida?&lt;br&gt;U/S — modo usuário pode acessar?&lt;br&gt;A — accessed (substituição)&lt;br&gt;D — dirty (precisa salvar em swap)&lt;br&gt;NX — proibido executar (anti-exploit)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="910" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Trabalho Nº3 — System Design da Memória — Artefato 2: Fluxo de Tradução de Endereço" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="50" y="1300" width="1069" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
