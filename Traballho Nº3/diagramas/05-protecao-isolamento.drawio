<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="claude-code" version="22.1.0">
  <diagram name="Proteção e Isolamento" id="protecao">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Proteção e Isolamento de Memória" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="77" y="30" width="1500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Os três pilares: espaços virtuais separados — permissões por página — modos de execução" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="77" y="75" width="1500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="pillar1_title" value="1. ESPAÇOS VIRTUAIS SEPARADOS POR PROCESSO" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="proc_a" value="&lt;b style='font-size:13px'&gt;Processo A&lt;/b&gt;&lt;br&gt;vaddr 0x400000 ───&gt; frame 0x1A00&lt;br&gt;vaddr 0x7FFE0000 ──&gt; frame 0xFF20&lt;br&gt;&lt;br&gt;tabela de páginas A&lt;br&gt;CR3_A ──&gt; árvore A" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="180" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="proc_b" value="&lt;b style='font-size:13px'&gt;Processo B&lt;/b&gt;&lt;br&gt;vaddr 0x400000 ───&gt; frame 0x4C00&lt;br&gt;vaddr 0x7FFE0000 ──&gt; frame 0x8800&lt;br&gt;&lt;br&gt;tabela de páginas B&lt;br&gt;CR3_B ──&gt; árvore B" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="340" y="180" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="cr3_note" value="&lt;b&gt;CR3&lt;/b&gt; é trocado em cada context switch.&lt;br&gt;Mesmo endereço virtual → frames físicos diferentes em processos diferentes.&lt;br&gt;Isolamento garantido pela MMU em hardware." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="335" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pillar2_title" value="2. PERMISSÕES POR PÁGINA (bits da PTE)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pte_header" value="&lt;b&gt;Cada acesso é verificado em hardware pela MMU&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="180" width="460" height="20" as="geometry" />
        </mxCell>
        <mxCell id="bit_p" value="&lt;b&gt;P&lt;/b&gt; — Present" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="210" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_p_desc" value="página em RAM?&lt;br&gt;P=0 → page fault" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="210" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_rw" value="&lt;b&gt;R/W&lt;/b&gt; — Read/Write" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="255" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_rw_desc" value="permite escrita?&lt;br&gt;tentativa em página R-O → SIGSEGV" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="255" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_us" value="&lt;b&gt;U/S&lt;/b&gt; — User/Super" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_us_desc" value="usuário pode acessar?&lt;br&gt;U=0 + ring 3 → SIGSEGV" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="300" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_nx" value="&lt;b&gt;NX&lt;/b&gt; — No Execute" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="345" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bit_nx_desc" value="página executável?&lt;br&gt;NX=1 + execução → SIGSEGV (anti-exploit)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="345" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pillar3_title" value="3. MODOS DE EXECUÇÃO (rings)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1100" y="130" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ring0" value="&lt;b style='font-size:13px'&gt;Ring 0 — Modo Kernel&lt;/b&gt;&lt;br&gt;&lt;br&gt;executa instruções privilegiadas&lt;br&gt;acessa todas as páginas&lt;br&gt;&lt;br&gt;onde rodam: kernel, drivers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1100" y="180" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ring3" value="&lt;b style='font-size:13px'&gt;Ring 3 — Modo Usuário&lt;/b&gt;&lt;br&gt;&lt;br&gt;só instruções não-privilegiadas&lt;br&gt;só páginas U=1&lt;br&gt;&lt;br&gt;onde rodam: processos comuns" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1340" y="180" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="transition" value="&lt;b&gt;Transições USUÁRIO → KERNEL:&lt;/b&gt;&lt;br&gt;• syscall (processo pede serviço)&lt;br&gt;• exceção (page fault, divisão por zero)&lt;br&gt;• interrupção (hardware sinaliza)&lt;br&gt;&lt;br&gt;A CPU pula para handler &lt;b&gt;pré-registrado&lt;/b&gt; pelo kernel; processo não escolhe destino." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1100" y="320" width="460" height="115" as="geometry" />
        </mxCell>
        <mxCell id="mmu_center_title" value="MMU = Guarda de Segurança em Hardware" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="77" y="470" width="1500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="mmu_diagram" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="1254" height="280" as="geometry" />
        </mxCell>
        <mxCell id="proc_acc" value="&lt;b&gt;Processo&lt;/b&gt;&lt;br&gt;tenta acesso a&lt;br&gt;endereço virtual" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="mmu_check" value="&lt;b&gt;MMU&lt;/b&gt;&lt;br&gt;• traduz vaddr&lt;br&gt;• checa bits R/W/X&lt;br&gt;• checa U/S vs ring&lt;br&gt;• checa P (presente?)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;verticalAlign=middle;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="580" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ok_path" value="&lt;b style='color:#82b366'&gt;✓ OK&lt;/b&gt;&lt;br&gt;Acesso à RAM&lt;br&gt;processo continua" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="860" y="540" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fault_path" value="&lt;b style='color:#b85450'&gt;✗ VIOLAÇÃO&lt;/b&gt;&lt;br&gt;exceção → kernel&lt;br&gt;kernel envia SIGSEGV / SIGBUS / OOM kill" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="860" y="680" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="kernel_resolve" value="&lt;b&gt;Kernel&lt;/b&gt;&lt;br&gt;decide: matar processo,&lt;br&gt;carregar página,&lt;br&gt;duplicar (COW), etc." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1180" y="610" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="mmu_a1" style="endArrow=classic;html=1;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="proc_acc" target="mmu_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mmu_a2_ok" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="mmu_check" target="ok_path">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mmu_a3_fault" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#b85450;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="mmu_check" target="fault_path">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mmu_a4_kernel" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d79b00;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="fault_path" target="kernel_resolve">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cow_panel_title" value="Bonus: Copy-on-Write (COW)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="77" y="830" width="1500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cow_step1" value="&lt;b&gt;1. fork()&lt;/b&gt;&lt;br&gt;filho herda mesmo espaço&lt;br&gt;todas as páginas R-O&lt;br&gt;(pai e filho apontam pros mesmos frames)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="870" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cow_step2" value="&lt;b&gt;2. um deles tenta escrever&lt;/b&gt;&lt;br&gt;MMU dispara fault (W=0)&lt;br&gt;kernel detecta: era página COW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="460" y="870" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cow_step3" value="&lt;b&gt;3. kernel duplica AQUELA página&lt;/b&gt;&lt;br&gt;cada um fica com seu frame&lt;br&gt;libera escrita" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="820" y="870" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cow_result" value="&lt;b&gt;Resultado:&lt;/b&gt; isolamento preservado&lt;br&gt;SEM o custo de copiar tudo no fork.&lt;br&gt;Páginas que ninguém modifica continuam compartilhadas." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1180" y="870" width="380" height="90" as="geometry" />
        </mxCell>
        <mxCell id="cow_a1" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="cow_step1" target="cow_step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cow_a2" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="cow_step2" target="cow_step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cow_a3" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="cow_step3" target="cow_result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="failures_panel" value="&lt;b&gt;ONDE A PROTEÇÃO PEGA (erros comuns do processo)&lt;/b&gt;&lt;br&gt;• Escrita em .text (R-O) → SIGSEGV (W=0)&lt;br&gt;• Execução de heap/data → SIGSEGV (NX=1)&lt;br&gt;• Acesso a página não-mapeada → SIGSEGV (P=0 fora de VMA)&lt;br&gt;• Acesso à área do kernel → SIGSEGV (U=0)&lt;br&gt;• Stack overflow → SIGSEGV (guard page invadida)&lt;br&gt;• Memória mapeada de arquivo truncado → SIGBUS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="990" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="hw_mitigations" value="&lt;b&gt;MITIGAÇÕES EM HARDWARE&lt;/b&gt;&lt;br&gt;• NX (No Execute) — pages de dados não-executáveis&lt;br&gt;• SMAP / SMEP — kernel não acessa páginas de usuário sem flag&lt;br&gt;• ASLR — randomização do layout a cada execução&lt;br&gt;• KPTI — tabelas separadas user/kernel (pós-Meltdown)&lt;br&gt;• IOMMU — proteção contra DMA attacks&lt;br&gt;• ECC — detecção de corrupção em RAM" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="990" width="740" height="140" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Trabalho Nº3 — System Design da Memória — Artefato 5: Proteção e Isolamento" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="77" y="1140" width="1500" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
